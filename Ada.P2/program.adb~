with Ada.Text_IO; use Ada.Text_IO;
with Ada.Integer_Text_IO; use Ada.Integer_Text_IO;
with Ada.Float_Text_IO; use Ada.Float_Text_IO;

procedure Program is
   
   function "-"(Heltal : in Integer; 
		Strang : in String) return Float is
  begin 
     return Float'Floor(Float(Heltal)-Float'Value(Strang));
  end "-";
  
  procedure Del2 (Flyttal1, Flyttal2 : out Float;
		  Summa : out Integer) is 
  begin
     for I in 1..2 loop
	Put("Mata in ett flyttal: ");
	case I is
	   when 1 =>
	      Get(Flyttal1);
	   when 2 => 
	      Get(Flyttal2);
	end case;
     end loop;
     Summa := Integer(Float'Ceiling(Flyttal1 + Flyttal2));
  end;
  
  
  function Del3 (Tecken : in Character) return Integer is
  begin
     return Integer(Float'Rounding(Float'Value((1 => Tecken)) / 32.7));
     
     -- Float'Value vill ha en sträng så här säger jag att det ska vara en 
     -- sträng med längden 1 och att vi sätter in vårt tecken.
     
     -- En annan lösning är att göra en sträng varaibel som är 1..1
     -- och sätta in vårt tecken på plats 1 och sen köra Float'Value(Sträng_Varaibel)
  end;
   
   Heltal: Integer;
   Strang : String(1..3);
   Flyttal1,Flyttal2 : Float;
   Tecken : Character;
      
begin
   
   -- DEL 1
   
   Put("Mata in ett heltal: ");
   Get(Heltal);
   Put("Mata in en sträng: ");
   Get(Strang);
   Put("Den beräknade differensen mellan ");
   Put(Heltal,Width => 0);
   Put(" och ");
   Put(Strang);
   Put(" blir ");
   Put(Heltal - Strang, Fore => 0, Aft => 1, Exp => 0);
   New_Line(2);
   
   -- DEL 2
   
   Del2(Flyttal1, Flyttal2, Heltal);
   Put("Du matade in flyttalet: ");
   Put(Flyttal1, Fore => 0, Aft => 1, Exp => 0);
   Put(" och flyttalet: ");
   Put(Flyttal2, Fore => 0, Aft => 1, Exp => 0);   
   Put(" och summan blev ");
   Put(Heltal, Width => 11);
   New_Line(2);
   
   -- DEL 3
   
   Put("Mata in ett tecken: ");
   Get(Tecken);
   Put("kvoten mellan ");
   Put(Tecken);
   Put(" och 32.7 blir ");
   Put(Del3(Tecken), Width => 0);
   
end;
