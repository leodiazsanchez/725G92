with Ada.Integer_Text_IO; use Ada.Integer_Text_IO;
with Ada.Text_IO; use Ada.Text_IO;

package body Sorted_List is 
   
   
   function Empty(List : in List_Type) return Boolean is
   begin
      
      if List = null then
	 return True;
      end if;
      
      return False;
      
   end;
   
   function Length(List : in List_Type) return Natural is
   begin

      if Empty(List) then
	 return 0;
      end if;
      
      return 1 + Length(List.Next);
      
   end;
   
   function Member(List : in List_Type; Key : in Integer) return Boolean is
   begin
      
      if Empty(List) then
	 return False;
      end if;
      
      if List.Num = Key then
	 return True;
      end if;
      
      return Member(List.Next,Key);
      
   end;
   
   procedure Insert_Sorted(List,Element : in out List_Type) is
      Temp : List_Type;
   begin
      
      if Empty(List) then
	 List := Element;
	 return;
      end if;
      
      if Element.Num < List.Num then
	 Temp := List;
	 List := Element;
	 List.Next := Temp;
	 return;
      end if;
      
      Insert_Sorted(List.Next,Element);
     
   end;

   procedure Insert(List : in out List_Type;
		    Num : in Integer) is
      Temp : List_Type;
   begin
      
      if Member(List,Num) then 
	 return;
      end if;
      
      Temp := new E_Type;
      Temp.Num := Num;
      
      Insert_Sorted(List,Temp);
          
   end;
   
   procedure Remove(List : in out List_Type; Num : in Integer) is
      Temp : List_Type;
   begin
      if Empty(List) or not Member(List,Num) then
	 raise No_Such_Element_Error;
      elsif List.Num = Num then
	 Temp := List.Next;
	 Delete(List);
	 List := Temp;
      else
	 Remove(List.Next,Num);	 
      end if;
   end;   
   
   procedure Put(List : in List_Type) is
   begin
      
      if Empty(List) then
	 return;
      end if;
      
      Put(" ");
      Put(List.Num, Width => 0);
      Put(List.Next);
   end;
   
end Sorted_List;
