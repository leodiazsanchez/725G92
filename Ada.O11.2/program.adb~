with Ada.Text_IO; use Ada.Text_IO;
with Ada.Integer_Text_IO; use Ada.Integer_Text_IO;
with Ada.Float_Text_IO; use Ada.Float_Text_IO;
with Ada.Command_Line; use Ada.Command_Line;
with Ada.Strings.Unbounded; use Ada.Strings.Unbounded;

procedure Program is
   
   ArgC,N : Integer;
   Program : Unbounded_String;
   Text : Unbounded_String;
   
begin
   ArgC := Argument_Count; 
   Program := To_Unbounded_String(Command_Name);
   
   if ArgC = 0 then
      Put_Line("Inga argument angivna.");
   elsif ArgC = 2 then
      N := Integer'Value(Argument(1));
      Text := To_Unbounded_String(Argument(2));
      Put("Meddelande: ");
      for I in 1..N loop
	 Put(To_String(Text));
      end loop;
      New_Line;
      Put("Programmet """ & To_String(Program) & """ avslutas.");
   else 
      Put_Line("Fel antal argument angivna.");
   end if;
end;
